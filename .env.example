# Copy to `.env`, fill values, never commit `.env`.

# Discord
DISCORD_BOT_TOKEN=

# --- OpenClaw Gateway（reply-bot 必須）---
# Chat completions: gateway.http.endpoints.chatCompletions.enabled = true
# https://docs.openclaw.ai/gateway/openai-http-api
OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_TOKEN=
# OPENCLAW_CHAT_MODEL=openclaw/default
# OPENCLAW_SESSION_USER=
# OPENCLAW_SESSION_KEY=
# OPENCLAW_MESSAGE_CHANNEL=discord
# OPENCLAW_MODEL_HEADER=
# OPENCLAW_PROMPT_PREFIX=
# OPENCLAW_GATEWAY_TIMEOUT_SEC=600

# 任意: 明示的に Cursor の HTTP ゲートウェイだけ使う場合（別ホストで agent-gateway を動かしているとき）
# DISCORD_LLM_BACKEND=cursor
# CURSOR_AGENT_GATEWAY_URL=http://192.168.11.34:9888
# GATEWAY_TOKEN=
# CURSOR_API_KEY=
# CURSOR_GATEWAY_TRUST_WORKSPACE=true
# CURSOR_GATEWAY_TIMEOUT_SEC=600
# AGENT_APPROVE_MCPS=false
# AGENT_REQUEST_TIMEOUT_SEC=600
