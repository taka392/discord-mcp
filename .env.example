# Copy to .env and set (never commit .env).
DISCORD_BOT_TOKEN=

# --- Optional: Discord → Cursor Agent (cursor-cli-homelab agent-gateway) ---
# LAN URL of POST /v1/prompt (e.g. http://192.168.11.34:9888 ). Unset = echo fallback only.
CURSOR_AGENT_GATEWAY_URL=

# Same value as gateway's GATEWAY_TOKEN when enforcement is enabled.
GATEWAY_TOKEN=

CURSOR_GATEWAY_TRUST_WORKSPACE=true
CURSOR_GATEWAY_TIMEOUT_SEC=600

# Prepended to every user message sent to the agent (e.g. "Reply in concise Japanese.")
# CURSOR_GATEWAY_PROMPT_PREFIX=
