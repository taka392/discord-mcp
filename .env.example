# Copy to `.env`, fill values, never commit `.env`.

# Discord
DISCORD_BOT_TOKEN=

# --- Bundled compose: Cursor agent-gateway と同じ Docker ネットワークで繋ぐ（推奨）---
# discord-reply-bot からサービス名で到達させる。
CURSOR_AGENT_GATEWAY_URL=http://agent-gateway:9888

# ゲートウェイと共通（Discord 側の Bearer でも使う）。
GATEWAY_TOKEN=

# gateway コンテナ側。ゲートウェイ側と同じ運用がよい。
GATEWAY_ENFORCE_TOKEN=false

# headless agent に必須（https://cursor.com/docs/cli/headless）。
# Cursor ダッシュボード等で発行したキー（Discord コンテナにも渡るが、この compose 単体でのみ）。
CURSOR_API_KEY=

# オプション: MCP を自動承認（Discord 自動応答など）
AGENT_APPROVE_MCPS=false

AGENT_REQUEST_TIMEOUT_SEC=600

CURSOR_GATEWAY_TRUST_WORKSPACE=true
CURSOR_GATEWAY_TIMEOUT_SEC=600

# Prepended to every user message sent to the agent (e.g. "Reply in concise Japanese.")
# CURSOR_GATEWAY_PROMPT_PREFIX=
