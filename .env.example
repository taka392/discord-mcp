# Copy to `.env`, fill values, never commit `.env`.

# docker compose: ``discord-reply-bot`` を起動する
COMPOSE_PROFILES=prod

# --- Discord ---
DISCORD_BOT_TOKEN=

# --- OpenClaw Gateway（**同一 VM / 同一ホスト**。OpenClaw は Docker の外で動いている前提）---
# ポートは運用に合わせて変更（openclaw gateway の listen と一致させる）
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_CHAT_MODEL=google/gemini-3.1-pro-preview
# OPENCLAW_GATEWAY_PASSWORD=
# OPENCLAW_SESSION_USER=
# OPENCLAW_SESSION_KEY=
# OPENCLAW_MESSAGE_CHANNEL=discord
# OPENCLAW_MODEL_HEADER=
# OPENCLAW_PROMPT_PREFIX=
# OPENCLAW_GATEWAY_TIMEOUT_SEC=600
# OPENCLAW_HTTP_CONNECT_SEC=30

# 別ホストの Gateway（Tailscale 等）へボットだけ離すレガシー構成の場合のみ書き換え。
# その場合は ``network_mode: host`` をオフにする別ファイルや手作業オーバーライドが必要になることがあります。

# 任意: 明示的に Cursor の HTTP ゲートウェイだけ使う場合
# DISCORD_LLM_BACKEND=cursor
# CURSOR_AGENT_GATEWAY_URL=http://192.168.11.34:9888
# GATEWAY_TOKEN=
# CURSOR_API_KEY=
# CURSOR_GATEWAY_TRUST_WORKSPACE=true
# CURSOR_GATEWAY_TIMEOUT_SEC=600
# AGENT_APPROVE_MCPS=false
# AGENT_REQUEST_TIMEOUT_SEC=600
